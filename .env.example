# Langfuse local stack — environment variables.
# setup.sh will copy this file to .env and fill in random values for REPLACE_ME_* placeholders.
# Do NOT commit .env (see .gitignore).

# ------ Infra passwords ------
POSTGRES_PASSWORD=REPLACE_ME_HEX16
CLICKHOUSE_PASSWORD=REPLACE_ME_HEX16
MINIO_ROOT_PASSWORD=REPLACE_ME_HEX16
REDIS_AUTH=REPLACE_ME_HEX16

# ------ Langfuse crypto secrets ------
# NEXTAUTH_SECRET: NextAuth session secret (32 bytes)
NEXTAUTH_SECRET=REPLACE_ME_HEX32
# ENCRYPTION_KEY: Langfuse data encryption (MUST be exactly 32 bytes hex)
ENCRYPTION_KEY=REPLACE_ME_HEX32
# SALT: password hash salt (16 bytes)
SALT=REPLACE_ME_HEX16

# ------ Langfuse initial project (auto-created on first boot) ------
# API keys the Claude Code hook will use to authenticate against Langfuse.
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-REPLACE_ME_HEX16
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-REPLACE_ME_HEX16

# ------ Langfuse admin user (for the web UI) ------
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_PASSWORD=REPLACE_ME_HEX8
